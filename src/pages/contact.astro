---
// お問い合わせページ
// フォームの送信先: Formspree（https://formspree.io）を使用
// 利用手順:
//   1. https://formspree.io でアカウント作成（無料プランあり）
//   2. 新規フォームを作成し、エンドポイントURLを取得
//   3. 下記 FORMSPREE_ENDPOINT の値を取得したURLに置き換える
//      例: https://formspree.io/f/xyzabcde

import BaseLayout from '../layouts/BaseLayout.astro';

const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';

const breadcrumbs = [{ name: 'お問い合わせ', url: '/contact' }];
---

<BaseLayout
  title="お問い合わせ"
  description="DCトレンド研究へのお問い合わせはこちらから。スポンサードコンテンツ・記事訂正・取材・メディア掲載などのご相談をお受けしています。"
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold mb-2 text-slate-900 dark:text-slate-100">
      お問い合わせ
    </h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">
      以下のフォームよりお気軽にご連絡ください。通常2〜3営業日以内にご返信します。
    </p>

    {/* お問い合わせ種別の案内 */}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-10">
      <div class="bg-slate-50 dark:bg-slate-800 rounded-lg p-4 text-center">
        <p class="text-2xl mb-2">📣</p>
        <p class="text-sm font-bold text-slate-700 dark:text-slate-300">スポンサード</p>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">記事・バナー広告のご相談</p>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-lg p-4 text-center">
        <p class="text-2xl mb-2">✏️</p>
        <p class="text-sm font-bold text-slate-700 dark:text-slate-300">記事の訂正・情報提供</p>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">誤情報・最新情報のご指摘</p>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800 rounded-lg p-4 text-center">
        <p class="text-2xl mb-2">🤝</p>
        <p class="text-sm font-bold text-slate-700 dark:text-slate-300">取材・コラボ</p>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">メディア掲載・共同制作</p>
      </div>
    </div>

    {/* お問い合わせフォーム */}
    <form
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="space-y-6"
      id="contact-form"
    >
      {/* お名前 */}
      <div>
        <label
          for="name"
          class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >
          お名前 <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="山田 太郎"
          class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
        />
      </div>

      {/* メールアドレス */}
      <div>
        <label
          for="email"
          class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >
          メールアドレス <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="example@company.com"
          class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
        />
      </div>

      {/* お問い合わせ種別 */}
      <div>
        <label
          for="type"
          class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >
          お問い合わせの種類 <span class="text-red-500">*</span>
        </label>
        <select
          id="type"
          name="type"
          required
          class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
        >
          <option value="" disabled selected>選択してください</option>
          <option value="sponsored">スポンサードコンテンツ・広告のご相談</option>
          <option value="correction">記事の訂正・情報提供</option>
          <option value="media">取材・メディア掲載のご相談</option>
          <option value="collaboration">コラボレーション・共同制作</option>
          <option value="other">その他</option>
        </select>
      </div>

      {/* 会社名（任意） */}
      <div>
        <label
          for="company"
          class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >
          会社名・組織名 <span class="text-xs text-slate-400">（任意）</span>
        </label>
        <input
          type="text"
          id="company"
          name="company"
          placeholder="株式会社〇〇"
          class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
        />
      </div>

      {/* お問い合わせ内容 */}
      <div>
        <label
          for="message"
          class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"
        >
          お問い合わせ内容 <span class="text-red-500">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows={6}
          placeholder="お問い合わせ内容をご記入ください。"
          class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition resize-y"
        ></textarea>
      </div>

      {/* プライバシーポリシーへの同意 */}
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="agree"
          name="agree"
          required
          class="mt-1 h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500"
        />
        <label for="agree" class="text-sm text-slate-600 dark:text-slate-400">
          <a href="/privacy" class="text-brand-600 dark:text-brand-400 hover:underline">
            プライバシーポリシー
          </a>
          に同意します <span class="text-red-500">*</span>
        </label>
      </div>

      {/* 送信ボタン */}
      <button
        type="submit"
        class="w-full sm:w-auto px-8 py-3 bg-brand-600 hover:bg-brand-700 text-white font-bold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
      >
        送信する
      </button>
    </form>

    {/* 送信後メッセージ（Formspree のリダイレクト先として使うか、JS で表示） */}
    <div id="form-success" class="hidden mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
      <p class="text-green-700 dark:text-green-400 font-medium">
        ✅ お問い合わせを受け付けました。2〜3営業日以内にご連絡します。
      </p>
    </div>

    {/* 注意事項 */}
    <div class="mt-8 p-4 bg-slate-50 dark:bg-slate-800 rounded-lg text-xs text-slate-500 dark:text-slate-400 leading-relaxed space-y-1">
      <p>・ご入力いただいた個人情報はお問い合わせへの回答のみに使用します。</p>
      <p>・内容によってはご返答できない場合があります。あらかじめご了承ください。</p>
      <p>・記事内容に関する法的な請求・削除依頼については、弁護士等を通じた正式な手続きにてお願いします。</p>
    </div>
  </div>
</BaseLayout>

<script>
  // Formspree の送信成功後にサンクスメッセージを表示
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const action = form.getAttribute('action') ?? '';

      // Formspree エンドポイントが未設定の場合はデモ表示
      if (action.includes('YOUR_FORM_ID')) {
        success.classList.remove('hidden');
        form.reset();
        return;
      }

      try {
        const res = await fetch(action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          success.classList.remove('hidden');
          form.reset();
          form.classList.add('hidden');
        }
      } catch {
        alert('送信中にエラーが発生しました。しばらく経ってから再度お試しください。');
      }
    });
  }
</script>
