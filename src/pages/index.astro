---
// トップページ — 編集メディア風レイアウト
// CHANGES from main:
//   - Adds NewsTicker bar at top
//   - Lead grid: hero (8 col) + 2 feature stack (4 col)
//   - Latest row: 4 cards
//   - Two-column lower: category sections (left, 8) + sidebar (right, 4)
//   - Per-category "featured + 2 cards" block instead of generic grid

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import NewsTicker from '../components/NewsTicker.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Thumbnail from '../components/Thumbnail.astro';
import Sidebar from '../components/Sidebar.astro';
import Icon from '../components/Icon.astro';

// --- Pull content -----------------------------------------------------------
const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft)
  .map(a => ({
    title: a.data.title,
    slug: a.id.replace(/\.mdx?$/, ''),
    summary: a.data.summary,
    category: a.data.category,
    tags: a.data.tags,
    publishedAt: a.data.published_at,
    isGlossary: false,
  }));

const glossaryEntries = (await getCollection('glossary'))
  .filter(g => !g.data.draft)
  .map(g => ({
    title: g.data.title,
    slug: g.id.replace(/\.mdx?$/, ''),
    summary: g.data.summary,
    category: '用語解説',
    tags: g.data.tags,
    publishedAt: g.data.published_at,
    reading: g.data.reading,
    isGlossary: true,
  }));

const all = [...articles, ...glossaryEntries].sort(
  (a, b) => b.publishedAt.localeCompare(a.publishedAt),
);

// --- Layout slots -----------------------------------------------------------
const lead       = all[0];
const features   = all.slice(1, 3);
const latestRow  = all.slice(3, 7);
const ranking    = all.slice(0, 5);
const termsPick  = glossaryEntries.slice(0, 5);

function byCategory(name: string) {
  return articles.filter(a => a.category === name).slice(0, 3);
}

const sections = [
  { name: 'AI・HPCインフラ', slug: 'ai-hpc',        kicker: 'AI · HPC' },
  { name: '電力・冷却技術',   slug: 'power-cooling', kicker: 'POWER · COOLING' },
  { name: '国内DC動向',       slug: 'japan-dc',      kicker: 'JAPAN DC' },
  { name: '海外DC動向',       slug: 'global-dc',     kicker: 'GLOBAL DC' },
] as const;

function formatDate(s: string) {
  return new Date(s)
    .toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })
    .replace(/\//g, '.');
}
---

<BaseLayout>

  {lead && <NewsTicker article={lead} />}

  <div class="max-w-6xl mx-auto px-4 py-8">

    {/* ============================================================
        LEAD GRID — hero (2/3) + 2 stacked features (1/3)
        ============================================================ */}
    {lead && (
      <section class="mb-12 grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-8">
          <ArticleCard {...lead} variant="hero" />
        </div>
        <div class="lg:col-span-4 flex flex-col gap-6 lg:border-l lg:border-slate-200 lg:dark:border-slate-800 lg:pl-8">
          {features.map(a => <ArticleCard {...a} variant="feature" />)}
        </div>
      </section>
    )}

    {/* ============================================================
        LATEST ROW
        ============================================================ */}
    {latestRow.length > 0 && (
      <section class="mb-14">
        <SectionHeader
          label="最新記事"
          kicker="LATEST"
          more="すべての記事"
          moreHref="/category/japan-dc"
        />
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {latestRow.map(a => <ArticleCard {...a} variant="standard" />)}
        </div>
      </section>
    )}

    {/* ============================================================
        TWO-COLUMN — category sections (8) + sidebar (4)
        ============================================================ */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

      {/* LEFT — category sections */}
      <div class="lg:col-span-8 space-y-12">
        {sections.map(sec => {
          const items = byCategory(sec.name);
          if (items.length === 0) return null;
          const [feature, ...rest] = items;
          return (
            <section>
              <SectionHeader
                label={sec.name}
                kicker={sec.kicker}
                more="このカテゴリの記事一覧"
                moreHref={`/category/${sec.slug}`}
              />

              {/* Featured row of this section: thumbnail + headline */}
              {feature && (
                <a
                  href={`/articles/${feature.slug}`}
                  class="group grid grid-cols-1 sm:grid-cols-2 gap-5 mb-4 no-underline"
                >
                  <Thumbnail category={feature.category} ratio="16/9" />
                  <div class="flex flex-col justify-center">
                    <div class="mb-2">
                      <span class="inline-block text-[10px] font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">
                        {feature.category}
                      </span>
                    </div>
                    <h3 class="font-serif font-bold text-[18px] leading-[1.45] text-slate-900 dark:text-slate-100 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors">
                      {feature.title}
                    </h3>
                    <p class="mt-2 text-[13px] leading-[1.85] text-slate-600 dark:text-slate-400 line-clamp-2">
                      {feature.summary}
                    </p>
                    <div class="mt-2 flex items-center gap-2 text-[11px] text-slate-500 dark:text-slate-400">
                      <Icon name="calendar" class="w-3 h-3" />
                      <time>{formatDate(feature.publishedAt)}</time>
                    </div>
                  </div>
                </a>
              )}

              {/* Remaining 2 cards */}
              {rest.length > 0 && (
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {rest.map(a => <ArticleCard {...a} variant="standard" />)}
                </div>
              )}
            </section>
          );
        })}
      </div>

      {/* RIGHT — sidebar */}
      <div class="lg:col-span-4">
        <Sidebar articles={ranking} terms={termsPick} />
      </div>
    </div>

    {/* Empty state */}
    {all.length === 0 && (
      <div class="text-center py-20 text-slate-400">
        <div class="flex justify-center mb-4 text-slate-300 dark:text-slate-600">
          <Icon name="signal-slash" class="w-12 h-12" />
        </div>
        <p class="text-lg font-bold">記事を準備中です</p>
        <p class="text-sm mt-2">しばらくお待ちください。</p>
      </div>
    )}
  </div>
</BaseLayout>
