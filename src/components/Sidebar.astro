---
// Sidebar — homepage right rail
// 3 widgets: Ranking (popular articles), Glossary picks, About strip
// CHANGES from main: NEW component — was missing in the original site

import SectionHeader from './SectionHeader.astro';
import ArticleCard from './ArticleCard.astro';
import Icon from './Icon.astro';

export interface Props {
  articles: Array<{
    title: string;
    slug: string;
    summary: string;
    category: string;
    tags: string[];
    publishedAt: string;
    isGlossary?: boolean;
  }>;
  terms: Array<{
    title: string;
    slug: string;
    reading: string;
    summary: string;
  }>;
}

const { articles, terms } = Astro.props;

const aboutItems = [
  { icon: 'eye',    title: '独立した第三者視点',   text: 'ベンダーに依存しない中立的な解説。' },
  { icon: 'bolt',   title: '高頻度更新',           text: '週3〜5本ペースで最新ニュースをお届け。' },
  { icon: 'wrench', title: '現場エンジニアの知見', text: '現役DCエンジニアのリアルな視点で解説。' },
] as const;
---

<aside class="lg:border-l lg:border-slate-200 lg:dark:border-slate-800 lg:pl-10">

  {/* Ranking */}
  <section>
    <SectionHeader label="人気記事" kicker="WEEKLY" />
    <div class="bg-white dark:bg-slate-900">
      {articles.slice(0, 5).map((a, i) => (
        <ArticleCard {...a} variant="compact" rank={i + 1} />
      ))}
    </div>
  </section>

  {/* Glossary picks */}
  <section class="mt-10">
    <SectionHeader label="用語をひく" kicker="GLOSSARY" />
    <div class="bg-white dark:bg-slate-900">
      {terms.slice(0, 5).map(t => (
        <a
          href={`/glossary/${t.slug}`}
          class="group flex items-baseline justify-between gap-3 py-2.5 no-underline border-b border-slate-200 dark:border-slate-800 last:border-b-0"
        >
          <div class="flex-1 min-w-0">
            <div class="font-serif font-bold text-[14px] text-slate-900 dark:text-slate-100 group-hover:text-brand-700 dark:group-hover:text-brand-300">
              {t.title.replace(/とは$/, '').replace(/（.+?）/, '')}
            </div>
            <div class="text-[10px] text-slate-500 dark:text-slate-400 mt-0.5">{t.reading}</div>
          </div>
          <Icon name="chevron-right" class="w-3 h-3 text-slate-400" />
        </a>
      ))}
    </div>
  </section>

  {/* About strip */}
  <section class="mt-10 border border-slate-200 dark:border-slate-800 p-5 bg-slate-50 dark:bg-slate-900">
    <div class="text-[10px] font-mono font-medium tracking-widest uppercase text-brand-700 dark:text-brand-400 mb-3">
      About DCトレンド研究
    </div>
    <div class="space-y-4">
      {aboutItems.map(item => (
        <div class="flex gap-3">
          <span class="flex-shrink-0 w-7 h-7 inline-flex items-center justify-center bg-brand-600 text-white">
            <Icon name={item.icon} class="w-4 h-4" />
          </span>
          <div>
            <div class="font-bold text-[13px] text-slate-900 dark:text-slate-100">{item.title}</div>
            <div class="text-[11px] text-slate-600 dark:text-slate-400 leading-relaxed mt-0.5">{item.text}</div>
          </div>
        </div>
      ))}
    </div>
  </section>
</aside>
