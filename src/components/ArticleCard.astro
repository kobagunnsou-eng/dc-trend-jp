---
// 記事カード — variant-aware editorial card
// CHANGES from main:
//   - Adds `variant` prop: 'standard' | 'hero' | 'feature' | 'list' | 'compact'
//   - Adds a Thumbnail at the top (or left for list/compact)
//   - Switches from rounded-lg card with hover-lift to flat editorial card with
//     border-color hover (matches major Japanese news sites)
//   - `compact` variant supports a `rank` number for ranking widgets

import { getCategorySlug } from '../config/site';
import Thumbnail from './Thumbnail.astro';
import Icon from './Icon.astro';

export interface Props {
  title: string;
  slug: string;
  summary: string;
  category: string;
  tags?: string[];
  publishedAt: string;
  isGlossary?: boolean;
  variant?: 'standard' | 'hero' | 'feature' | 'list' | 'compact';
  rank?: number;
}

const {
  title,
  slug,
  summary,
  category,
  tags = [],
  publishedAt,
  isGlossary = false,
  variant = 'standard',
  rank,
} = Astro.props;

const href = isGlossary ? `/glossary/${slug}` : `/articles/${slug}`;

function formatDate(s: string): string {
  return new Date(s)
    .toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })
    .replace(/\//g, '.');
}
const dateStr = formatDate(publishedAt);
---

{/* ----------------- HERO — lead story ----------------- */}
{variant === 'hero' && (
  <a href={href} class="group block no-underline">
    <div class="relative overflow-hidden">
      <Thumbnail category={category} ratio="16/9" />
      <div class="absolute top-3 left-3">
        <span class="inline-block text-[11px] font-medium tracking-wide px-2 py-0.5 bg-brand-600 text-white">{category}</span>
      </div>
    </div>
    <div class="pt-5">
      <h2 class="font-serif font-bold text-[26px] md:text-[30px] leading-[1.35] tracking-tight text-slate-900 dark:text-slate-50 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors">
        {title}
      </h2>
      <p class="mt-3 text-[14px] leading-[1.85] text-slate-600 dark:text-slate-400 line-clamp-3">{summary}</p>
      <div class="mt-3 flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
        <Icon name="calendar" class="w-3.5 h-3.5" />
        <time>{dateStr}</time>
      </div>
    </div>
  </a>
)}

{/* ----------------- FEATURE — secondary lead ----------------- */}
{variant === 'feature' && (
  <a href={href} class="group block no-underline">
    <div class="relative overflow-hidden">
      <Thumbnail category={category} ratio="16/9" />
      <div class="absolute top-2 left-2">
        <span class="inline-block text-[11px] font-medium tracking-wide px-2 py-0.5 bg-brand-600 text-white">{category}</span>
      </div>
    </div>
    <div class="pt-3">
      <h3 class="font-serif font-bold text-[18px] leading-[1.4] text-slate-900 dark:text-slate-100 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors">
        {title}
      </h3>
      <div class="mt-2 flex items-center gap-2 text-[11px] text-slate-500 dark:text-slate-400">
        <time>{dateStr}</time>
      </div>
    </div>
  </a>
)}

{/* ----------------- STANDARD — main grid card ----------------- */}
{variant === 'standard' && (
  <a href={href} class="group block bg-white dark:bg-slate-900 no-underline border border-slate-200 dark:border-slate-800 hover:border-brand-400 dark:hover:border-brand-600 transition-colors">
    <Thumbnail category={category} ratio="16/9" />
    <div class="p-4">
      <div class="mb-2">
        <span class="category-badge">{category}</span>
      </div>
      <h3 class="font-bold text-[15px] leading-[1.5] text-slate-900 dark:text-slate-100 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors line-clamp-3">
        {title}
      </h3>
      <div class="mt-3 flex items-center gap-2 text-[11px] text-slate-500 dark:text-slate-400">
        <Icon name="calendar" class="w-3 h-3" />
        <time>{dateStr}</time>
      </div>
    </div>
  </a>
)}

{/* ----------------- LIST — horizontal, thumbnail left ----------------- */}
{variant === 'list' && (
  <a href={href} class="group flex gap-3 no-underline py-3 border-b border-slate-200 dark:border-slate-800 last:border-b-0">
    <div class="w-[88px] flex-shrink-0">
      <Thumbnail category={category} ratio="4/3" />
    </div>
    <div class="flex-1 min-w-0">
      <div class="mb-1">
        <span class="text-[10px] font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">{category}</span>
      </div>
      <h3 class="font-bold text-[13px] leading-[1.5] text-slate-900 dark:text-slate-100 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors line-clamp-3">
        {title}
      </h3>
      <time class="mt-1 block text-[10px] text-slate-500 dark:text-slate-400">{dateStr}</time>
    </div>
  </a>
)}

{/* ----------------- COMPACT — ranking / glossary picks ----------------- */}
{variant === 'compact' && (
  <a href={href} class="group flex gap-3 py-2.5 no-underline border-b border-slate-200 dark:border-slate-800 last:border-b-0">
    {rank != null && (
      <span class:list={[
        'flex-shrink-0 w-6 h-6 flex items-center justify-center font-serif text-base font-bold',
        rank <= 3 ? 'text-brand-600 dark:text-brand-400' : 'text-slate-400 dark:text-slate-600',
      ]}>{rank}</span>
    )}
    <div class="flex-1 min-w-0">
      <h4 class="text-[13px] leading-[1.5] font-medium text-slate-800 dark:text-slate-200 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors line-clamp-2">
        {title}
      </h4>
      <time class="mt-1 block text-[10px] text-slate-500 dark:text-slate-400">{dateStr}</time>
    </div>
  </a>
)}
