---
// 記事カードコンポーネント（一覧・トップページで使用）

import { getCategorySlug } from '../config/site';

export interface Props {
  title: string;
  slug: string;
  summary: string;
  category: string;
  tags: string[];
  publishedAt: string;
  isGlossary?: boolean;
}

const {
  title,
  slug,
  summary,
  category,
  tags,
  publishedAt,
  isGlossary = false,
} = Astro.props;

const href = isGlossary ? `/glossary/${slug}` : `/articles/${slug}`;
const categorySlug = getCategorySlug(category);
const categoryHref = isGlossary ? '/glossary' : `/category/${categorySlug}`;

// 日付フォーマット
function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<article class="article-card bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-5 flex flex-col gap-2">
  {/* カテゴリ・日付 */}
  <div class="flex items-center justify-between text-xs text-slate-500 dark:text-slate-400">
    <a href={categoryHref} class="category-badge">
      {category}
    </a>
    <time datetime={publishedAt}>{formatDate(publishedAt)}</time>
  </div>

  {/* タイトル */}
  <h2 class="text-base font-bold leading-snug">
    <a
      href={href}
      class="text-slate-900 dark:text-slate-100 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
    >
      {title}
    </a>
  </h2>

  {/* 概要 */}
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">
    {summary}
  </p>

  {/* タグ */}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.slice(0, 3).map(tag => (
        <span class="text-xs px-1.5 py-0.5 bg-slate-100 dark:bg-slate-700 rounded text-slate-500 dark:text-slate-400">
          #{tag}
        </span>
      ))}
    </div>
  )}

  {/* 続きを読む */}
  <a
    href={href}
    class="text-xs text-brand-600 dark:text-brand-400 hover:underline mt-auto pt-1 font-medium"
  >
    続きを読む →
  </a>
</article>
