---
// Icon — Heroicons outline 24/2 inlined. Replaces the emoji set the production
// site used in homepage trio / article meta / empty states.

export interface Props {
  name:
    | 'calendar' | 'pencil' | 'arrow-right' | 'arrow-trending' | 'bolt'
    | 'eye' | 'wrench' | 'book' | 'rss' | 'window-stack' | 'globe'
    | 'server' | 'chevron-right' | 'signal-slash' | 'search'
    | 'sun' | 'moon' | 'menu';
