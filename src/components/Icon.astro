const d = paths[name];
---

{d && (
  <svg
    class={className}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    {d.split(' M').map((seg, i) => (
      <path d={(i === 0 ? seg : 'M' + seg)} />
    ))}
  </svg>
)}
