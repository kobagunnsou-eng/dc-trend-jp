---
// SectionHeader — editorial section heading with brand-capsule accent, kicker,
// underline rule, and an optional "more →" link.

import Icon from './Icon.astro';

export interface Props {
  label: string;
  kicker?: string;
  more?: string;
  moreHref?: string;
  accent?: boolean;
}

const { label, kicker, more, moreHref, accent = true } = Astro.props;
---

<div class="flex items-end justify-between mb-5 border-b-2 border-slate-900 dark:border-slate-200 pb-2">
  <div class="flex items-baseline gap-3">
    {accent && <span class="inline-block w-1 h-6 bg-brand-600" />}
    <h2 class="font-serif text-[20px] font-bold tracking-tight text-slate-900 dark:text-slate-100">
      {label}
    </h2>
    {kicker && (
      <span class="text-[11px] font-mono tracking-wider uppercase text-slate-500 dark:text-slate-500">
        {kicker}
      </span>
    )}
  </div>
  {more && moreHref && (
    <a
      href={moreHref}
      class="group flex items-center gap-1 text-[12px] font-medium text-slate-700 dark:text-slate-300 hover:text-brand-700 dark:hover:text-brand-300 no-underline"
    >
      {more}
      <Icon name="chevron-right" class="w-3 h-3 transition-transform group-hover:translate-x-0.5" />
    </a>
  )}
</div>
