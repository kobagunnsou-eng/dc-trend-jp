---
// ヘッダーコンポーネント
// ナビゲーション・ダークモードトグル・モバイルメニュー対応

import { SITE_CONFIG, NAV_LINKS } from '../config/site';
---

<header class="sticky top-0 z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">

      {/* サイトロゴ */}
      <a
        href="/"
        class="flex items-center gap-2 font-bold text-lg text-brand-700 dark:text-brand-400 hover:opacity-80 transition-opacity"
      >
        {/* データセンターアイコン（SVGインライン） */}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12H3m2 0a9 9 0 1018 0 9 9 0 00-18 0zm9-9v2m0 14v2M12 3a9 9 0 100 18" />
          <rect x="8" y="8" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 10h6M9 12h6M9 14h4"/>
        </svg>
        <span>{SITE_CONFIG.name}</span>
      </a>

      {/* デスクトップナビゲーション */}
      <nav class="hidden lg:flex items-center gap-1" aria-label="メインナビゲーション">
        {NAV_LINKS.map(link => (
          <a
            href={link.href}
            class="text-sm px-3 py-1.5 rounded text-slate-600 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      {/* 右側のアクション */}
      <div class="flex items-center gap-2">
        {/* ダークモード切り替えボタン */}
        <button
          id="theme-toggle"
          aria-label="ダークモード切り替え"
          class="theme-toggle p-2 rounded text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
        >
          {/* 太陽アイコン（ライトモード時） */}
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          {/* 月アイコン（ダークモード時） */}
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>

        {/* モバイルメニューボタン */}
        <button
          id="mobile-menu-btn"
          aria-label="メニューを開く"
          aria-expanded="false"
          class="lg:hidden p-2 rounded text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    {/* モバイルメニュー（初期は非表示） */}
    <nav
      id="mobile-menu"
      class="lg:hidden hidden pb-4"
      aria-label="モバイルナビゲーション"
    >
      <div class="flex flex-col gap-1 pt-2 border-t border-slate-200 dark:border-slate-700">
        {NAV_LINKS.map(link => (
          <a
            href={link.href}
            class="text-sm px-3 py-2 rounded text-slate-600 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  // モバイルメニューのトグル
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
