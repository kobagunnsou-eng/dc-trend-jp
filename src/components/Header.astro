---
// ヘッダー — editorial newspaper style
// Replaces src/components/Header.astro
// CHANGES from main:
//   - Top utility strip with today's date + RSS link
//   - Serif wordmark + monospace kicker ("DATA CENTER TREND JAPAN")
//   - Square brand-blue logo tile (instead of inline icon)
//   - Nav moved to its own row below wordmark, with active-state top accent
//   - Search button (no-op for now, wired when search ships)

import { SITE_CONFIG, NAV_LINKS } from '../config/site';
import Icon from './Icon.astro';

const today = new Date().toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric', weekday: 'short',
});

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="sticky top-0 z-50 bg-white/95 dark:bg-slate-950/95 backdrop-blur border-b border-slate-200 dark:border-slate-800">

  {/* Utility strip — date + RSS / about (hidden on mobile) */}
  <div class="border-b border-slate-100 dark:border-slate-900 hidden md:block">
    <div class="max-w-6xl mx-auto px-4 h-7 flex items-center justify-between text-[11px] text-slate-500 dark:text-slate-500">
      <span class="font-mono tabular-nums">{today}</span>
      <div class="flex items-center gap-4">
        <a href="/about" class="hover:text-brand-700 dark:hover:text-brand-400 no-underline">このサイトについて</a>
        <a href="/rss.xml" class="hover:text-brand-700 dark:hover:text-brand-400 no-underline flex items-center gap-1">
          <Icon name="rss" class="w-3 h-3" /> RSS
        </a>
      </div>
    </div>
  </div>

  {/* Main wordmark row */}
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <a href="/" class="flex items-center gap-3 no-underline group">
        <span class="inline-flex items-center justify-center w-9 h-9 bg-brand-600 text-white">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12H3m2 0a9 9 0 1018 0 9 9 0 00-18 0zm9-9v2m0 14v2M12 3a9 9 0 100 18"/>
            <rect x="8" y="8" width="8" height="8" rx="1" fill="currentColor" opacity="0.2"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 10h6M9 12h6M9 14h4"/>
          </svg>
        </span>
        <div class="flex flex-col leading-none">
          <span class="font-serif font-black text-[22px] tracking-tight text-slate-900 dark:text-slate-50 group-hover:text-brand-700 dark:group-hover:text-brand-300 transition-colors">
            {SITE_CONFIG.name}
          </span>
          <span class="text-[10px] font-mono tracking-[0.18em] text-slate-500 dark:text-slate-500 mt-1">
            DATA CENTER TREND JAPAN
          </span>
        </div>
      </a>

      <div class="flex items-center gap-1">
        <button
          aria-label="検索"
          class="p-2 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors"
        >
          <Icon name="search" class="w-5 h-5" />
        </button>
        <button
          id="theme-toggle"
          aria-label="ダークモード切り替え"
          class="p-2 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors"
        >
          <Icon name="sun"  class="w-5 h-5 hidden dark:block" />
          <Icon name="moon" class="w-5 h-5 block dark:hidden" />
        </button>
        {/* Mobile menu trigger */}
        <button
          id="mobile-menu-btn"
          aria-label="メニューを開く"
          aria-expanded="false"
          class="lg:hidden p-2 text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors"
        >
          <Icon name="menu" class="w-5 h-5" />
        </button>
      </div>
    </div>

    {/* Desktop nav row — below the wordmark */}
    <nav class="hidden lg:flex items-stretch border-t border-slate-200 dark:border-slate-800" aria-label="メインナビゲーション">
      {NAV_LINKS.map(link => {
        const active = isActive(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              'relative px-3 py-2.5 text-[13px] font-medium no-underline transition-colors',
              active
                ? 'text-brand-700 dark:text-brand-300'
                : 'text-slate-700 dark:text-slate-300 hover:text-brand-700 dark:hover:text-brand-300',
            ]}
          >
            {link.label}
            {active && <span class="absolute left-3 right-3 -top-px h-0.5 bg-brand-600 dark:bg-brand-400" />}
          </a>
        );
      })}
    </nav>

    {/* Mobile nav drawer */}
    <nav id="mobile-menu" class="lg:hidden hidden pb-4" aria-label="モバイルナビゲーション">
      <div class="flex flex-col gap-1 pt-2 border-t border-slate-200 dark:border-slate-800">
        {NAV_LINKS.map(link => (
          <a
            href={link.href}
            class="text-sm px-3 py-2 rounded text-slate-600 dark:text-slate-300 hover:text-brand-700 dark:hover:text-brand-300 hover:bg-slate-100 dark:hover:bg-slate-900 transition-colors no-underline"
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn  = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
